{
  "expo": {
    "name": "BugSplat Expo Example",
    "slug": "bugsplat-expo-example",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bug.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/bug.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bugsplat.expo.example",
      "infoPlist": {
        "NSMotionUsageDescription": "We use motion data to detect shake gestures for opening the feedback dialog."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/bug.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.bugsplat.expo.example"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      ["@bugsplat/expo", {
        "database": "<your-database>",
        "enableSymbolUpload": true
      }],
      ["expo-build-properties", {
        "android": {
          "minSdkVersion": 26
        }
      }]
    ]
  }
}
